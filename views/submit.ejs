<!DOCTYPE html>
<html>

<head>

<title>Praktikum Submit</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
    background:#ffd6e7;
}

.pink{
    background:#ff69b4;
    color:white;
}

</style>

</head>

<body>

<div class="container mt-5">

<div class="card">

<div class="card-header pink text-center">
    Form Submit Tugas - TRPL
</div>

<div class="card-body">

<form
action="/submit"
method="POST"
enctype="multipart/form-data">

<div class="mb-3">
<input
class="form-control"
name="nim"
placeholder="NIM">
</div>

<div class="mb-3">
<input
class="form-control"
name="name"
placeholder="Nama">
</div>

<div class="mb-3">
<input
class="form-control"
name="class"
placeholder="Kelas">
</div>

<div class="mb-3">
<input
class="form-control"
name="course"
placeholder="Mata Kuliah">
</div>

<div class="mb-3">
<input
type="file"
class="form-control"
name="file">
</div>

<button
class="btn pink w-100">
Kirim Tugas
</button>

</form>

</div>

</div>

</div>

</body>
</html>