<!DOCTYPE html>
<html>

<head>

<title>Daftar Tugas</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body>

<div class="container mt-5">

<h2>📋 Daftar Tugas</h2>

<table class="table table-bordered">

<tr>
<th>NIM</th>
<th>Nama</th>
<th>Kelas</th>
<th>Mata Kuliah</th>
<th>File</th>
<th>Status</th>
</tr>

<% data.forEach(item => { %>

<tr>

<td><%= item.nim %></td>
<td><%= item.name %></td>
<td><%= item.class %></td>
<td><%= item.course %></td>
<td><%= item.file_url %></td>
<td><%= item.status %></td>

</tr>

<% }) %>

</table>

</div>

</body>
</html>